# ==========================================
# CONFIGURATION APPLICATION MOBILE (EXPO)
# ==========================================

# 🚨 ATTENTION : NE METTEZ JAMAIS 'localhost' ICI 🚨
# Remplacez l'IP ci-dessous par l'adresse IPv4 locale de votre PC 
# (Tapez 'ipconfig' sur Windows ou 'ifconfig' sur Mac/Linux pour la trouver).
# Le port doit être celui du BackEnd (3001 par défaut).
EXPO_PUBLIC_API_URL=http://192.168.1.196:3001/api